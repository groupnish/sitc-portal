# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

SECRET_KEY=your-secret-key-min-32-chars-change-this
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-change-this

# Render.com provides this automatically when you add PostgreSQL
# For local dev, use SQLite (default) — no change needed
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Your team Gmail account (the one that sends notifications)
GMAIL_USER=yourcompany@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# CORS — comma-separated frontend URLs
CORS_ORIGINS=http://localhost:5173,https://your-github-pages-url.github.io

# Google Drive (optional — for auto-saving PDFs)
GOOGLE_DRIVE_CREDENTIALS=
GOOGLE_DRIVE_FOLDER_ID=
